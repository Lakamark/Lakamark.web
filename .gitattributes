# Normalize line endings automatically
* text=auto

# Force LF for source files
*.php text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.twig text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf

# Windows specific files
*.bat text eol=crlf
*.cmd text eol=crlf