{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "types": ["vite/client", "node"],
    "baseUrl": ".",
  },
  "include": [
    "assets/**/*.ts",
    "assets/**/*.d.ts",
    "vite.config.ts",
    "vite/**/*.ts"
  ]
}