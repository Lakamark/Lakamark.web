<!DOCTYPE html>
<html lang="en">
    <head>
        <title>{% block title 'Laka Mark' %} - Laka Mark</title>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="turbo-cache-control" content="no-cache">
        {% block metas %}{% endblock metas %}
        {% block fbmetas %}{% endblock fbmetas %}
        {% block twittermetas %}{% endblock %}
        <link rel="preconnect" href="https://fonts.bunny.net">
        <link href="https://fonts.bunny.net/css?family=roboto:400,500,700" rel="stylesheet">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <script>
            window.LmkConfig = Object.freeze({
                userId: {{ app.user ? app.user.id : 'null' }},
                roles: {{ app.user ? app.user.roles|json_encode|raw : '[]' }},
                isPremium: {{ is_granted('ROLE_PREMIUM') ? 'true' : 'false' }},
                isLogged: {{ app.user ? 'true' : 'false' }},
                preferredTheme: {{ (app.user and app.user.preferredTheme is defined) ? app.user.preferredTheme|json_encode|raw : 'null' }}
            });
        </script>
        {% block stylesheets %}
            {{ vite_link('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ vite_script('app') }}
        {% endblock %}
    </head>
    <body>
    <div class="theme-flash"></div>
        <div class="page-wrapper">
            {% include '/partials/header.html.twig' %}
            <main class="page-content">
                <!-- HERE -->
                <button class="theme-toggle">
                    Switch theme
                </button>
                {% block body %}{% endblock %}
            </main>
            {% include '/partials/footer.html.twig' %}
        </div>
        <spotlight-bar target=".header__nav a"></spotlight-bar>
    </body>
</html>
